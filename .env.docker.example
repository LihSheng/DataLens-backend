# Docker compose example env (service-host DNS works inside the compose network)
APP_ENV=development
SECRET_KEY=change-me-in-production-min-32-chars
# Dedicated local dev ports (prefer 5333); keep 5173 for backward compatibility.
ALLOWED_ORIGINS=http://localhost:5333,http://localhost:5173,https://yourdomain.vercel.app

# Dev-only auth bypass (set true only for local dev)
DEV_AUTH_BYPASS=false
DEV_AUTH_EMAIL=dev@local.test
DEV_AUTH_NAME=Dev User
DEV_AUTH_ROLE=admin

# Database (compose service name)
DATABASE_URL=postgresql+asyncpg://raguser:ragpass@postgres:5432/ragdb

# Redis (compose service name)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
SEMANTIC_CACHE_ENABLED=true

# Vector store
VECTORSTORE_TYPE=chroma
CHROMA_PERSIST_PATH=./data/chroma

# LLM
GROQ_API_KEY=
USE_PROVIDER=groq
GROQ_MODEL=llama-3.3-70b-versatile
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-Text-01

# Phoenix observability (compose service name)
PHOENIX_BASE_URL=http://phoenix:6006
PHOENIX_COLLECTOR_ENDPOINT=http://phoenix:6006/v1/traces
PHOENIX_ENABLED=true
OTEL_EXPORT_ENABLED=true

# Debug
LOG_LLM_PROMPT=false

# File storage
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=50

# JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
