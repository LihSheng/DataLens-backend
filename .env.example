# FastAPI
APP_ENV=development
SECRET_KEY=change-me-in-production-min-32-chars
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.vercel.app
DEV_AUTH_BYPASS=false
DEV_AUTH_EMAIL=dev@local.test
DEV_AUTH_NAME=Dev User
DEV_AUTH_ROLE=admin

# Database
DATABASE_URL=postgresql+asyncpg://raguser:ragpass@localhost:5432/ragdb

# Redis
REDIS_URL=redis://localhost:6379/0
SEMANTIC_CACHE_ENABLED=false

# Vector store (choose one)
VECTORSTORE_TYPE=chroma
CHROMA_PERSIST_PATH=./data/chroma
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=rag-index

# LLM — Groq (free, fast) is the default
GROQ_API_KEY=
USE_PROVIDER=groq
GROQ_MODEL=llama-3.3-70b-versatile
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-Text-01

# Embeddings
EMBEDDING_MODEL=text-embedding-02

# Milvus (optional)
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=rag_docs

# Reranker (optional)
COHERE_API_KEY=
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Phoenix observability
PHOENIX_BASE_URL=http://localhost:6006
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces
PHOENIX_ENABLED=false
OTEL_EXPORT_ENABLED=false
LOG_LLM_PROMPT=false

# File storage
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=50

# JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
